{
  "name": "autoreviewer-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single self-contained HTML tool for the AutoReviewer document-review lifecycle (Train Persona / Run Review / Respond to Review).",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node build/build.js",
    "build:html": "node build/build.js --release html/autoreviewer-workbench.html",
    "build:redline": "node build/build-redline.js",
    "check:compliance": "node build/check-compliance.js",
    "fixtures:gen": "python3 fixtures/generate.py",
    "verify:zip": "node scripts/roundtrip-fixtures.mjs /tmp/ar-zip-roundtrip && python3 scripts/verify_zip_roundtrip.py fixtures /tmp/ar-zip-roundtrip"
  },
  "devDependencies": {
    "@xmldom/xmldom": "^0.9.10",
    "esbuild": "^0.24.0",
    "happy-dom": "^20.10.6",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
